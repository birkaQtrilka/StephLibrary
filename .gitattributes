###############################################################################
# Default text normalization
###############################################################################

* text=auto

###############################################################################
# Force LF for source/code/config files
#
# Prevents Windows CRLF noise across Unity/macOS/Linux tooling.
###############################################################################

*.cs        text eol=lf
*.cpp       text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.inl       text eol=lf
*.ixx       text eol=lf
*.cxx       text eol=lf

*.shader    text eol=lf
*.compute   text eol=lf
*.cginc     text eol=lf

*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

*.asmdef    text eol=lf
*.meta      text eol=lf
*.unity     text eol=lf
*.prefab    text eol=lf
*.mat       text eol=lf
*.asset     text eol=lf

###############################################################################
# Windows-specific scripts
###############################################################################

*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

###############################################################################
# Unix shell scripts
###############################################################################

*.sh        text eol=lf

###############################################################################
# Binary assets
###############################################################################

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.tga       binary
*.dds       binary
*.fbx       binary
*.blend     binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.mp4       binary
*.mov       binary
*.zip       binary
*.7z        binary
*.dll       binary
*.so        binary
*.dylib     binary
*.a         binary
*.lib       binary
*.exe       binary

###############################################################################
# Optional: Visual Studio solution/project handling
###############################################################################

*.sln       text eol=crlf
*.vcxproj   text eol=crlf
*.csproj    text eol=crlf